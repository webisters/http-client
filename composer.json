{
    "name": "webisters/http-client",
    "description": "Webisters HTTP Client Library",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "api",
        "http-client",
        "http",
        "client",
        "request",
        "response",
        "curl"
    ],
    "authors": [
        {
            "name": "Hafiz Muhammad Moaz",
            "email": "hafizmoazkhalid@gmail.com",
            "homepage": "https://github.com/HafizMMoaz"
        }
    ],
    "homepage": "https://webisters.com/packages/http-client",
    "support": {
        "email": "support@webisters.com",
        "issues": "https://github.com/webisters/http-client/issues",
        "forum": "https://github.com/webisters/forum",
        "source": "https://github.com/webisters/http-client",
        "docs": "https://webisters.com"
    },
    "funding": [
        {
            "type": "Webisters Sponsor",
            "url": "https://webisters.com/sponsor"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-fileinfo": "*",
        "ext-json": "*",
        "webisters/helpers": "*",
        "webisters/http": "*"
    },
    "require-dev": {
        "webisters/coding-standard": "*",
        "jetbrains/phpstorm-attributes": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Framework\\HTTP\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\HTTP\\Client\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}


